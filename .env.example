# 微信公众号文章批量抓取脚本 - 环境变量配置文件
# 复制此文件为 .env 并修改配置值

# ==================== 必需配置 ====================
# ⚠️ 必须设置 OUTPUT_DIR，否则脚本无法运行！
# 设置文章保存目录（Windows 使用正斜杠 / 或双反斜杠 \\\\）
# OUTPUT_DIR=C:/Users/username/Desktop/文章下载


# ==================== 可选配置 ====================

# 文章列表 CSV 文件路径（默认：脚本目录下的 articles_with_publish_date.csv）
# ARTICLES_CSV_FILE=./articles_with_publish_date.csv


# 请求间隔配置（秒）- 防止被封，数值越大越安全
# MIN_DELAY=1
# MAX_DELAY=2

# 图片下载间隔配置（秒）
# IMG_MIN_DELAY=0.5
# IMG_MAX_DELAY=1.5


# 重试配置
# MAX_RETRIES=3
